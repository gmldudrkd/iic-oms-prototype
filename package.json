{
  "name": "iic-oms",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "nvm-use": "command -v nvm >/dev/null || source ~/.nvm/nvm.sh; nvm install 22.14.0 && nvm use",
    "update-structure": "chmod +x .cursor/scripts/update-directory-structure.sh && bash .cursor/scripts/update-directory-structure.sh",
    "prelocal": "npm run nvm-use && npm run update-structure",
    "local": "npm run codegen:types && env-cmd -f .env.localhost.target node server.js",
    "build:local": "env-cmd -f .env.localhost.target next build",
    "start:local": "env-cmd -f .env.localhost.target next start",
    "build": "next build",
    "start": "next start",
    "dev": "next dev",
    "prototype": "env-cmd -f .env.prototype next dev -p 3000",
    "build:prototype": "env-cmd -f .env.prototype next build",
    "lint": "next lint",
    "lint-error": "eslint . --quiet",
    "prepare": "husky",
    "codegen:types": "node scripts/gen-types.mjs && node scripts/split-contracts.mjs"
  },
  "dependencies": {
    "@auth/core": "^0.34.2",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@fontsource/roboto": "^5.1.1",
    "@hookform/resolvers": "^5.2.2",
    "@mui/icons-material": "^6.4.8",
    "@mui/material": "^6.4.5",
    "@mui/x-charts": "^8.20.0",
    "@mui/x-data-grid": "^8.9.1",
    "@mui/x-data-grid-generator": "^7.27.0",
    "@mui/x-data-grid-pro": "^7.29.8",
    "@mui/x-date-pickers": "^7.28.0",
    "@mui/x-date-pickers-pro": "^7.28.0",
    "@tanstack/react-query": "^5.66.7",
    "@tanstack/react-query-devtools": "^5.66.7",
    "@toolpad/core": "^0.12.0",
    "@types/marked": "^5.0.2",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.13",
    "env-cmd": "^10.1.0",
    "jwt-decode": "^4.0.0",
    "lodash": "^4.17.21",
    "lodash.debounce": "^4.0.8",
    "marked": "^15.0.7",
    "material-ui-popup-state": "^5.3.3",
    "next": "^14.2.35",
    "next-auth": "^4.24.11",
    "next-navigation-guard": "^0.1.2",
    "notistack": "^3.0.2",
    "react": "^18",
    "react-dom": "^18",
    "react-dropzone": "^14.3.8",
    "react-hook-form": "^7.54.2",
    "react-number-format": "^5.4.3",
    "redux-devtools-extension": "^2.13.9",
    "tailwind-merge": "^3.0.2",
    "usehooks-ts": "^3.1.1",
    "xlsx": "^0.18.5",
    "zod": "^3.25.76",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@rushstack/eslint-config": "^4.1.1",
    "@tanstack/eslint-plugin-query": "^5.66.1",
    "@types/lodash": "^4.17.20",
    "@types/lodash.debounce": "^4.0.9",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@typescript-eslint/eslint-plugin": "^8.24.1",
    "@typescript-eslint/parser": "^8.24.1",
    "agentation": "^2.2.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eta": "^2.2.0",
    "husky": "^9.1.7",
    "postcss": "^8.5.3",
    "postcss-import": "^15.1.0",
    "postcss-loader": "^7.3.3",
    "postcss-preset-env": "^9.3.0",
    "prettier": "^3.5.1",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "swagger-typescript-api": "^13.2.13",
    "tailwindcss": "^3.4.17",
    "typescript": "^5"
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx}": [
      "prettier --write",
      "eslint --cache --fix"
    ]
  }
}
